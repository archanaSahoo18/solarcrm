# Stage 1: Build the JAR
FROM maven:3.8.4-openjdk-17 AS builder
WORKDIR /build

# Copy and download dependencies
COPY pom.xml .
RUN mvn dependency:go-offline

# Copy source and build
COPY src ./src
RUN mvn clean package -DskipTests

# Stage 2: Run the JAR
FROM openjdk:17-jdk-slim
WORKDIR /app

# Copy the JAR and rename it explicitly to app.jar
# We use /build/target/ to be absolutely sure where it's coming from
COPY --from=builder /build/target/*.jar /app/app.jar

# Give read and execute permissions to the jar file
RUN chmod +x /app/app.jar

# Expose port
EXPOSE 8080

# Run using the absolute path to the jar
ENTRYPOINT ["java", "-Xmx300m", "-jar", "/app/app.jar"]